  nextRotationAt        DateTime? @map("next_rotation_at")
  rotationPeriodDays    Int      @default(90) @map("rotation_period_days")
  compromiseDetectedAt  DateTime? @map("compromise_detected_at")
  revokedAt             DateTime? @map("revoked_at")

  @@index([status])
  @@index([nextRotationAt])
  @@map("mpc_distributed_keys")
}

model MpcKeyShare {
  id                  String   @id @default(cuid())
  keyId               String   @map("key_id")
  shareIndex          Int      @map("share_index")
  shareData           String   @map("share_data") // Encrypted
  location            String   // AWS_HSM, GCP_HSM, ON_PREM_HSM, AZURE_KEY_VAULT
  hsmKeyId            String   @map("hsm_key_id")
  publicKeyCommitment String   @map("public_key_commitment")
  createdAt           DateTime @default(now()) @map("created_at")
  lastUsedAt          DateTime? @map("last_used_at")
  isActive            Boolean  @default(true) @map("is_active")

  @@index([keyId, shareIndex])
  @@index([location, isActive])
  @@map("mpc_key_shares")
}

// ─── Strategy Marketplace Models ─────────────────────────────────────────────

model TradingStrategy {
  id                  String   @id @default(cuid())
  name                String
  description         String?
  developerAddress    String   @map("developer_address")
  strategyType        String   @map("strategy_type")
  executionModule     String   @map("execution_module") // Docker/WASM
  riskLevel           String   @map("risk_level")
  pricingModel        String   @map("pricing_model")
  priceUsdCents       Int?     @map("price_usd_cents")
  profitSharePercent  Decimal? @db.Decimal(5, 2) @map("profit_share_percent")
  maxPositionSize     Decimal? @db.Decimal(18, 4) @map("max_position_size")
  stopLossPercent     Decimal? @db.Decimal(5, 2) @map("stop_loss_percent")
  supportedPairs      String[] @map("supported_pairs")
  totalReturn         Decimal? @db.Decimal(18, 4) @map("total_return")
  sharpeRatio         Decimal? @db.Decimal(5, 2) @map("sharpe_ratio")
  maxDrawdown         Decimal? @db.Decimal(5, 4) @map("max_drawdown")
  winRate             Decimal? @db.Decimal(5, 4) @map("win_rate")
  totalTrades         Int?     @map("total_trades")
  subscriberCount     Int      @default(0) @map("subscriber_count")
  totalAUM            Decimal? @db.Decimal(18, 4) @map("total_aum")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([strategyType, isActive])
  @@index([riskLevel, isActive])
  @@index([sharpeRatio])
  @@index([developerAddress])
  @@map("trading_strategies")
}

model CopyTradeSubscription {
  id                String   @id @default(cuid())
  strategyId        String   @map("strategy_id")
  userAddress       String   @map("user_address")
  allocationAmount  Decimal  @db.Decimal(18, 4) @map("allocation_amount")
  maxAllocation     Decimal? @db.Decimal(18, 4) @map("max_allocation")
  stopLossOverride  Decimal? @db.Decimal(5, 2) @map("stop_loss_override")
  status            String   @default("ACTIVE")
  subscribedAt      DateTime @default(now()) @map("subscribed_at")
  lastSyncAt        DateTime @default(now()) @map("last_sync_at")
  totalProfit       Decimal? @db.Decimal(18, 4) @map("total_profit")
  totalFeesPaid     Decimal? @db.Decimal(18, 4) @map("total_fees_paid")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([strategyId, status])
  @@index([userAddress])
  @@map("copy_trade_subscriptions")
}

model StrategyBacktestResult {
  id                  String   @id @default(cuid())
  strategyId          String   @map("strategy_id")
  startDate           DateTime @map("start_date")
  endDate             DateTime @map("end_date")
  initialCapital      Decimal  @db.Decimal(18, 4) @map("initial_capital")
  finalCapital        Decimal  @db.Decimal(18, 4) @map("final_capital")
  totalReturn         Decimal  @db.Decimal(18, 4) @map("total_return")
  annualizedReturn    Decimal  @db.Decimal(18, 4) @map("annualized_return")
  sharpeRatio         Decimal  @db.Decimal(5, 2) @map("sharpe_ratio")
  sortinoRatio        Decimal  @db.Decimal(5, 2) @map("sortino_ratio")
  maxDrawdown         Decimal  @db.Decimal(5, 4) @map("max_drawdown")
  winRate             Decimal  @db.Decimal(5, 4) @map("win_rate")
  totalTrades         Int      @map("total_trades")
  equityCurve         Json?    @map("equity_curve")
  monthlyReturns      Json?    @map("monthly_returns")
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([strategyId, startDate, endDate])
  @@map("strategy_backtest_results")
}
