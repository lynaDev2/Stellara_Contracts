// Blockchain Transaction Queue Models
enum TransactionQueuePriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum TransactionQueueStatus {
  QUEUED
  PROCESSING
  SUBMITTED
  STUCK
  CONFIRMED
  FAILED
  CANCELLED
  DEAD_LETTER
}

model BlockchainTransactionQueueItem {
  id                 String                   @id @default(cuid())
  idempotencyKey     String                   @unique @map("idempotency_key")
  signerAddress      String                   @map("signer_address")
  contractAddress    String                   @map("contract_address")
  functionName       String                   @map("function_name")
  payload            Json
  metadata           Json?
  priority           TransactionQueuePriority @default(NORMAL)
  status             TransactionQueueStatus   @default(QUEUED)
  nonce              BigInt?
  feeBid             BigInt?                  @map("fee_bid")
  maxFee             BigInt?                  @map("max_fee")
  txHash             String?                  @map("tx_hash")
  retryCount         Int                      @default(0) @map("retry_count")
  maxRetries         Int                      @default(5) @map("max_retries")
  nextAttemptAt      DateTime?                @map("next_attempt_at")
  lastError          String?                  @map("last_error")
  result             Json?
  submittedAt        DateTime?                @map("submitted_at")
  confirmedAt        DateTime?                @map("confirmed_at")
  processingStartedAt DateTime?               @map("processing_started_at")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  attempts           BlockchainTransactionAttempt[]

  @@index([status, priority, createdAt])
  @@index([signerAddress, status])
  @@index([nextAttemptAt])
  @@map("blockchain_tx_queue_items")
}

model BlockchainTransactionAttempt {
  id            String                 @id @default(cuid())
  queueItemId   String                 @map("queue_item_id")
  queueItem     BlockchainTransactionQueueItem @relation(fields: [queueItemId], references: [id], onDelete: Cascade)
  attemptNumber Int                    @map("attempt_number")
  nonce         BigInt?
  feeBid        BigInt?                @map("fee_bid")
  txHash        String?                @map("tx_hash")
  status        TransactionQueueStatus
  error         String?
  rawResponse   Json?                  @map("raw_response")
  createdAt     DateTime               @default(now()) @map("created_at")

  @@index([queueItemId, attemptNumber])
  @@index([txHash])
  @@map("blockchain_tx_attempts")
}

model BlockchainNonceState {
  signerAddress String   @id @map("signer_address")
