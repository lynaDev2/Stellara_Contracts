// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Prisma v7: datasource connection URL is configured in prisma.config.ts

generator client {
  provider = "prisma-client-js"
}

// Provider is declared here for @db attribute support.
// Connection URL is in prisma.config.ts (Prisma v7+)
datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(cuid())
  name            String?
  walletAddress   String   @unique @map("wallet_address")
  profileData     Json?    @map("profile_data")
  reputationScore Int      @default(0) @map("reputation_score")
  trustScore      Int      @default(500) @map("trust_score")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Notification fields
  phoneNumber      String? @unique @map("phone_number")
  email            String? @unique @map("email_encrypted")
  pushSubscription Json?   @map("push_subscription")

  // Encrypted PII fields
  phoneEncrypted   Json? @map("phone_encrypted")
  ssnEncrypted     Json? @map("ssn_encrypted")
  addressEncrypted Json? @map("address_encrypted")

  // Auth fields
  roles              Role[]  @default([USER])
  hashedRefreshToken String? @map("hashed_refresh_token")

  // Tenant relation (optional — null for platform-level users)
  tenantId String? @map("tenant_id")
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  // Relations
  createdProjects      Project[]            @relation("ProjectCreator")
  contributions        Contribution[]
  reputationHistory    ReputationHistory[]
  notificationSettings NotificationSetting?
  notifications        Notification[]
  proposals            TransactionProposal[]
  tenantMembers       TenantMember[]
  experimentAssignments ExperimentAssignment[]
  verificationSessions VerificationSession[]
  userLocations       UserLocation[]
  marginAccount        MarginAccount?

  @@unique([tenantId, email])
  @@unique([tenantId, walletAddress])
  @@index([tenantId, id])
  @@index([tenantId, email])
  @@index([tenantId, walletAddress])
  @@map("users")
}

model UserLocation {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress       String   @map("ip_address")
  country         String?
  region          String?
  city            String?
  latitude        Float?
  longitude       Float?
  isp             String?
  isVpn           Boolean  @default(false) @map("is_vpn")
  isTor           Boolean  @default(false) @map("is_tor")
  isProxy         Boolean  @default(false) @map("is_proxy")
  userAgent       String?  @map("user_agent")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([ipAddress])
  @@map("user_locations")
}

model CollateralAsset {
  id              String   @id @default(cuid())
  symbol          String   @unique
  name            String
  haircut         Decimal  @db.Decimal(5, 4) // e.g., 0.10 for 10% haircut
  isLiquidatable  Boolean  @default(true)
  minPledgeAmount Decimal  @db.Decimal(18, 4)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  pledges         CollateralPledge[]

  @@map("collateral_assets")
}

model MarginAccount {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  user              User     @relation(fields: [userId], references: [id])
  totalBorrowed     Decimal  @default(0) @db.Decimal(18, 4) @map("total_borrowed")
  totalCollateralUsd Decimal  @default(0) @db.Decimal(18, 4) @map("total_collateral_usd")
  ltvRatio          Decimal  @default(0) @db.Decimal(5, 4) @map("ltv_ratio") // current Loan-to-Value
  healthFactor      Decimal  @default(1.0) @db.Decimal(5, 4) @map("health_factor")
  lastMarginCallAt  DateTime? @map("last_margin_call_at")
  status            MarginAccountStatus @default(HEALTHY)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  pledges           CollateralPledge[]
  loans             Loan[]
  liquidations      Liquidation[]

  @@map("margin_accounts")
}

model CollateralPledge {
  id                String   @id @default(cuid())
  marginAccountId   String   @map("margin_account_id")
  marginAccount     MarginAccount @relation(fields: [marginAccountId], references: [id])
  assetSymbol       String   @map("asset_symbol")
  asset             CollateralAsset @relation(fields: [assetSymbol], references: [symbol])
  amount            Decimal  @db.Decimal(18, 4)
  lockedAmount      Decimal  @default(0) @db.Decimal(18, 4) @map("locked_amount")
  lastValuationUsd  Decimal? @db.Decimal(18, 4) @map("last_valuation_usd")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([marginAccountId, assetSymbol])
  @@map("collateral_pledges")
}

model Loan {
  id                String   @id @default(cuid())
  marginAccountId   String   @map("margin_account_id")
  marginAccount     MarginAccount @relation(fields: [marginAccountId], references: [id])
  assetSymbol       String   @map("asset_symbol")
  amount            Decimal  @db.Decimal(18, 4)
  interestRate      Decimal  @db.Decimal(5, 4) @map("interest_rate")
  accruedInterest   Decimal  @default(0) @db.Decimal(18, 4) @map("accrued_interest")
  lastInterestAccrual DateTime @default(now()) @map("last_interest_accrual")
  status            LoanStatus @default(ACTIVE)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("loans")
}

model Liquidation {
  id                String   @id @default(cuid())
  marginAccountId   String   @map("margin_account_id")
  marginAccount     MarginAccount @relation(fields: [marginAccountId], references: [id])
  liquidatorAddress String   @map("liquidator_address")
  collateralSymbol  String   @map("collateral_symbol")
  collateralAmount  Decimal  @db.Decimal(18, 4) @map("collateral_amount")
  loanSymbol        String   @map("loan_symbol")
  loanAmount        Decimal  @db.Decimal(18, 4) @map("loan_amount")
  liquidationFee    Decimal  @db.Decimal(18, 4) @map("liquidation_fee")
  timestamp         DateTime @default(now())

  @@map("liquidations")
}

enum MarginAccountStatus {
  HEALTHY
  MARGIN_CALL
  LIQUIDATION_PENDING
  LIQUIDATED
}

enum LoanStatus {
  ACTIVE
  PAID
  LIQUIDATED
}

model Project {
  id           String        @id @default(cuid())
  contractId   String        @unique @map("contract_id")
  creatorId    String        @map("creator_id")
  creator      User          @relation("ProjectCreator", fields: [creatorId], references: [id])
  title        String
  description  String?
  category     String
  goal         BigInt
  currentFunds BigInt        @default(0) @map("current_funds")
  deadline     DateTime
  ipfsHash     String?       @map("ipfs_hash")
  status       ProjectStatus @default(ACTIVE)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  // Relations
  contributions Contribution[]
  milestones    Milestone[]

  @@map("projects")
}

model Contribution {
  id              String   @id @default(cuid())
  transactionHash String   @unique @map("transaction_hash")
  investorId      String   @map("investor_id")
  investor        User     @relation(fields: [investorId], references: [id])
  projectId       String   @map("project_id")
  project         Project  @relation(fields: [projectId], references: [id])
  amount          BigInt
  timestamp       DateTime @default(now())
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("contributions")
}

model Milestone {
  id             String          @id @default(cuid())
  projectId      String          @map("project_id")
  project        Project         @relation(fields: [projectId], references: [id])
  title          String
  description    String?
  fundingAmount  BigInt          @map("funding_amount")
  status         MilestoneStatus @default(PENDING)
  completionDate DateTime?       @map("completion_date")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@map("milestones")
}

model ReputationHistory {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  scoreChange Int      @map("score_change")
  reason      String
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("reputation_history")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  SUSPENDED
}

enum MilestoneStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  FUNDED
}

model LedgerCursor {
  id             String   @id @default(cuid())
  network        String   @unique
  lastLedgerSeq  Int      @map("last_ledger_seq")
  lastLedgerHash String?  @map("last_ledger_hash")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("ledger_cursors")
}

model ProcessedEvent {
  id              String   @id @default(cuid())
  eventId         String   @unique @map("event_id")
  network         String
  ledgerSeq       Int      @map("ledger_seq")
  contractId      String   @map("contract_id")
  eventType       String   @map("event_type")
  transactionHash String   @map("transaction_hash")
  contractType    String?  @map("contract_type")
  decodedData     Json?    @map("decoded_data")
  abiVersion      String?  @map("abi_version")
  processedAt     DateTime @default(now()) @map("processed_at")

  @@index([contractId, eventType])
  @@map("processed_events")
}

model LedgerHeader {
  sequence  Int      @id
  hash      String   @unique
  prevHash  String   @map("prev_hash")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([sequence])
  @@map("ledger_headers")
}

model ContractAbiRegistry {
  id              String               @id @default(uuid())
  contractAddress String               @unique @map("contract_address")
  contractType    String               @map("contract_type")
  displayName     String               @map("display_name")
  network         String               @default("stellar")
  description     String?
  status          AbiRegistryStatus    @default(ACTIVE)
  currentVersion  String?              @map("current_version")
  metadata        Json?
  createdBy       String?              @map("created_by")
  updatedBy       String?              @map("updated_by")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  versions        ContractAbiVersion[]

  @@index([contractType, network])
  @@index([status, updatedAt])
  @@map("contract_abi_registries")
}

model ContractAbiVersion {
  id              String              @id @default(uuid())
  registryId      String              @map("registry_id")
  registry        ContractAbiRegistry @relation(fields: [registryId], references: [id], onDelete: Cascade)
  version         String
  isCurrent       Boolean             @default(false) @map("is_current")
  isDeprecated    Boolean             @default(false) @map("is_deprecated")
  abiSchema       Json                @map("abi_schema")
  contractSchema  Json                @map("contract_schema")
  functionSchemas Json                @map("function_schemas")
  eventSchemas    Json                @map("event_schemas")
  changelog       String?
  compatibility   Json?
  createdBy       String?             @map("created_by")
  createdAt       DateTime            @default(now()) @map("created_at")

  @@unique([registryId, version])
  @@index([registryId, isCurrent])
  @@index([version])
  @@map("contract_abi_versions")
}

model IndexerLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  metadata  Json?
  timestamp DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")

  @@index([timestamp])
  @@index([level])
  @@map("indexer_logs")
}

model NotificationSetting {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  user                User     @relation(fields: [userId], references: [id])
  emailEnabled        Boolean  @default(true) @map("email_enabled")
  pushEnabled         Boolean  @default(false) @map("push_enabled")
  smsEnabled          Boolean  @default(false) @map("sms_enabled")
  websocketEnabled    Boolean  @default(true) @map("websocket_enabled")
  notifyContributions Boolean  @default(true) @map("notify_contributions")
  notifyMilestones    Boolean  @default(true) @map("notify_milestones")
  notifyDeadlines     Boolean  @default(true) @map("notify_deadlines")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("notification_settings")
}

model Notification {
  id         String                 @id @default(cuid())
  userId     String                 @map("user_id")
  user       User                   @relation(fields: [userId], references: [id])
  type       NotificationType
  title      String
  message    String
  read       Boolean                @default(false)
  data       Json? // Optional metadata (e.g., projectId)
  createdAt  DateTime               @default(now()) @map("created_at")
  deliveries NotificationDelivery[]

  @@index([userId])
  @@map("notifications")
}

model NotificationDelivery {
  id             String              @id @default(cuid())
  notificationId String              @map("notification_id")
  notification   Notification        @relation(fields: [notificationId], references: [id])
  channel        NotificationChannel
  status         DeliveryStatus      @default(PENDING)
  errorMessage   String?             @map("error_message")
  attempts       Int                 @default(0)
  lastAttemptAt  DateTime?           @map("last_attempt_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@map("notification_deliveries")
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  WEBSOCKET
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

model EmailOutbox {
  id        String      @id @default(cuid())
  to        String
  subject   String
  html      String
  status    EmailStatus @default(PENDING)
  attempts  Int         @default(0)
  lastError String?     @map("last_error")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([status])
  @@map("email_outbox")
}

enum NotificationType {
  CONTRIBUTION
  MILESTONE
  DEADLINE
  SYSTEM
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  USER
  VIEWER
  SUPPORT_AGENT
  SUPPORT_MANAGER
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
  ARCHIVED
}

enum TenantPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum ApiOveragePolicy {
  HARD_STOP
  BILL_OVERAGE
}

model Tenant {
  id        String       @id @default(cuid())
  name      String       @unique
  slug      String       @unique
  status    TenantStatus @default(ACTIVE)
  plan      TenantPlan   @default(FREE)
  metadata  Json?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  settings             TenantSettings?
  calls                Call[]
  stakeLedgers         StakeLedger[]
  claims               Claim[]
  pools                Pool[]
  users                User[]
  auditLogs            TenantAuditLog[]
  tenantMembers        TenantMember[]
  subscription         Subscription?
  webhookSubscriptions WebhookSubscription[]
  webhookEvents        WebhookEvent[]

  @@index([status])
  @@map("tenants")
}

model TenantSettings {
  id                    String           @id @default(cuid())
  tenantId              String           @unique @map("tenant_id")
  tenant                Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  maxUsers              Int              @default(10) @map("max_users")
  maxProjects           Int              @default(5) @map("max_projects")
  apiCallsPerMonthLimit Int              @default(100000) @map("api_calls_per_month_limit")
  storageGbLimit        Int              @default(100) @map("storage_gb_limit")
  apiOveragePolicy      ApiOveragePolicy @default(HARD_STOP) @map("api_overage_policy")
  allowPublicProjects   Boolean          @default(true) @map("allow_public_projects")
  notificationsEnabled  Boolean          @default(true) @map("notifications_enabled")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  @@map("tenant_settings")
}

model TenantAuditLog {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  action    String
  actorId   String?  @map("actor_id")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([action])
  @@map("tenant_audit_logs")
}

enum Permission {
  // Project Permissions
  CREATE_PROJECT
  UPDATE_PROJECT
  DELETE_PROJECT
  VIEW_PROJECT

  // Contribution Permissions
  MAKE_CONTRIBUTION
  VIEW_CONTRIBUTION

  // User/Admin Permissions
  MANAGE_USERS
  MANAGE_ROLES
  VIEW_SENSITIVE_DATA

  // System Permissions
  MANAGE_SYSTEM
}

model TokenBlacklist {
  id        String   @id @default(cuid())
  token     String   @unique // The exact JWT access token string
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("token_blacklist")
}

model MultiSigAccount {
  id              String   @id @default(cuid())
  accountId       String   @unique @map("account_id") // Stellar account ID
  name            String?
  thresholds      Json     // { masterWeight, lowThreshold, medThreshold, highThreshold }
  signers         Json     // Array of { key, weight, type }
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  proposals       TransactionProposal[]

  @@map("multi_sig_accounts")
}

model TransactionProposal {
  id              String   @id @default(cuid())
  multiSigId      String   @map("multi_sig_id")
  multiSig        MultiSigAccount @relation(fields: [multiSigId], references: [id])
  creatorId       String   @map("creator_id")
  creator         User     @relation(fields: [creatorId], references: [id])
  xdr             String   // The unsigned or partially signed base64 XDR
  description     String?
  status          ProposalStatus @default(PENDING)
  expiresAt       DateTime @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  signatures      ProposalSignature[]

  @@map("transaction_proposals")
}

model ProposalSignature {
  id              String   @id @default(cuid())
  proposalId      String   @map("proposal_id")
  proposal        TransactionProposal @relation(fields: [proposalId], references: [id])
  signerAddress   String   @map("signer_address") // Who signed it
  signature       String   // The actual signature part
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([proposalId, signerAddress])
  @@map("proposal_signatures")
}

enum ProposalStatus {
  PENDING
  READY
  SUBMITTED
  EXPIRED
  FAILED
}

model EncryptionAuditLog {
  id             String   @id @default(cuid())
  keyId          String   @map("key_id")
  userId         String?  @map("user_id")
  action         String // ENCRYPT, DECRYPT, KEY_ROTATE, KEY_REVOKE
  field          String?  @map("field_name")
  table          String?  @map("table_name")
  timestamp      DateTime @default(now())
  ipAddress      String   @map("ip_address")
  userAgent      String?  @map("user_agent")
  success        Boolean  @default(false)
  error          String?  @map("error_message")
  processingTime Int      @map("processing_time_ms")

  @@index([timestamp])
  @@index([keyId])
  @@index([action])
  @@index([success])
  @@map("encryption_audit_logs")
}

model Call {
  id          String      @id @default(uuid())
  tenantId    String
  description String
  outcome     CallOutcome @default(PENDING)
  resolvedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  stakes StakeLedger[]

  @@index([tenantId, id])
  @@index([tenantId, outcome])
  @@index([tenantId, createdAt])
  @@index([tenantId, expiresAt])
  @@map("calls")
}

model StakeLedger {
  id               String           @id @default(uuid())
  tenantId         String
  callId           String
  userAddress      String
  amount           Decimal          @db.Decimal(18, 4)
  position         Position
  profitLoss       Decimal?         @db.Decimal(18, 4)
  transactionHash  String?
  resolutionStatus ResolutionStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  call   Call   @relation(fields: [callId], references: [id], onDelete: Restrict)

  @@unique([tenantId, transactionHash])
  @@index([tenantId, id])
  @@index([tenantId, callId])
  @@index([tenantId, userAddress])
  @@index([tenantId, createdAt])
  @@map("stake_ledger")
}

model Claim {
  id          String      @id @default(uuid())
  tenantId    String
  poolId      String?
  userAddress String
  amount      Decimal     @db.Decimal(18, 4)
  status      ClaimStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  pool   Pool?  @relation(fields: [poolId], references: [id], onDelete: SetNull)

  @@index([tenantId, id])
  @@index([tenantId, poolId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, userAddress])
  @@map("claims")
}

model Pool {
  id                 String   @id @default(uuid())
  tenantId           String
  name               String
  totalCapacity      Decimal  @default(0) @db.Decimal(18, 4)
  lockedAmount       Decimal  @default(0) @db.Decimal(18, 4)
  availableLiquidity Decimal  @default(0) @db.Decimal(18, 4)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  claims Claim[]

  @@unique([tenantId, name])
  @@index([tenantId, id])
  @@index([tenantId, name])
  @@index([tenantId, createdAt])
  @@map("pools")
}

enum CallOutcome {
  YES
  NO
  PENDING
}

enum Position {
  YES
  NO
}

enum ResolutionStatus {
  PENDING
  RESOLVED
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

model TenantMember {
  id        String     @id @default(uuid())
  tenantId  String
  userId    String
  role      TenantRole @default(MEMBER)
  createdAt DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, role])
  @@map("tenant_members")
}

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
}

// ─── Centralized Config Management ───────────────────────────────────────────

model ConfigEntry {
  id        String      @id @default(uuid())
  key       String
  value     String
  scope     ConfigScope @default(GLOBAL)
  tenantId  String?     @map("tenant_id")
  userId    String?     @map("user_id")
  encrypted Boolean     @default(false)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@unique([key, scope, tenantId, userId])
  @@index([scope, tenantId])
  @@index([key])
  @@map("config_entries")
}

model FeatureFlag {
  id         String   @id @default(uuid())
  key        String
  enabled    Boolean  @default(false)
